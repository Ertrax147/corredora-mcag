---
// src/components/AboutUs.astro
const stats = [
  { label: "Años de Experiencia", value: "15+" },
  { label: "Propiedades Vendidas", value: "2.5K+" },
  { label: "Clientes Satisfechos", value: "98%" },
  { label: "Profesionales", value: "50+" },
];

const timeline = [
  { year: "2009", title: "Fundación de MACG" },
  { year: "2014", title: "1,000 propiedades vendidas" },
  { year: "2018", title: "Expansión a seguros" },
  { year: "2026", title: "Líderes del mercado" },
];
---

<section id="nosotros" class="py-24 bg-slate-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span
        class="text-blue-600 font-bold text-xs uppercase tracking-widest bg-blue-50 px-3 py-1 rounded-full"
        >Nosotros</span
      >
      <h2 class="text-4xl font-black text-slate-900 mt-6 mb-4">
        Confianza que Construye Hogares
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto italic">
        Más de 15 años ayudando a familias y empresas a encontrar su espacio
        ideal.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-24">
      {
        stats.map((stat) => (
          <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm text-center">
            <p class="text-4xl font-black text-slate-900 mb-2">{stat.value}</p>
            <p class="text-gray-400 text-xs uppercase font-bold tracking-tighter">
              {stat.label}
            </p>
          </div>
        ))
      }
    </div>

    <div class="relative">
      <h3 class="text-center text-xl font-bold text-slate-900 mb-12 italic">
        Nuestra Trayectoria
      </h3>

      <div
        class="hidden lg:block absolute top-[5.5rem] left-0 w-full h-0.5 bg-gray-200"
      >
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          timeline.map((item) => (
            <div class="relative bg-white p-6 rounded-2xl border border-gray-100 shadow-sm z-10 text-center">
              <div class="w-12 h-12 bg-[#0f172a] text-white rounded-xl flex items-center justify-center font-bold mb-4 mx-auto shadow-lg">
                {item.year}
              </div>
              <p class="text-slate-700 font-medium text-sm italic">
                {item.title}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
