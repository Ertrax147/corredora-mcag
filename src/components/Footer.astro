---
// src/components/Footer.astro
---
<footer class="bg-[#0f172a] text-gray-400 pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="border-b border-gray-800 pb-16 mb-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-2xl font-bold text-white mb-2">Mantente Informado</h2>
          <p class="text-sm">Recibe las últimas propiedades y ofertas exclusivas directamente en tu correo.</p>
        </div>
        <form class="flex gap-2">
          <input 
            type="email" 
            placeholder="tu@email.com" 
            class="flex-1 bg-gray-800/50 border border-gray-700 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-blue-500 transition"
          />
          <button class="bg-white text-[#0f172a] px-6 py-3 rounded-xl font-bold text-sm hover:bg-gray-200 transition">
            Suscribir
          </button>
        </form>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="space-y-6">
        <div class="flex flex-col leading-tight text-white">
          <span class="text-xl font-black tracking-tight">CORREDORA MACG</span>
          <span class="text-[10px] text-gray-500 font-medium tracking-[0.2em] uppercase">Propiedades y Seguros</span>
        </div>
        <p class="text-sm leading-relaxed">
          Tu socio de confianza en el mercado inmobiliario desde 2009. Transformamos sueños en hogares reales.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-8 h-8 rounded-lg bg-gray-800 flex items-center justify-center hover:bg-blue-600 transition text-white">f</a>
          <a href="#" class="w-8 h-8 rounded-lg bg-gray-800 flex items-center justify-center hover:bg-pink-600 transition text-white">i</a>
          <a href="#" class="w-8 h-8 rounded-lg bg-gray-800 flex items-center justify-center hover:bg-blue-400 transition text-white">in</a>
        </div>
      </div>

      <div>
        <h3 class="text-white font-bold mb-6">Propiedades</h3>
        <ul class="space-y-4 text-sm">
          <li><a href="#" class="hover:text-white transition">Comprar</a></li>
          <li><a href="#" class="hover:text-white transition">Vender</a></li>
          <li><a href="#" class="hover:text-white transition">Arrendar</a></li>
          <li><a href="#" class="hover:text-white transition">Tasaciones</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-bold mb-6">Seguros</h3>
        <ul class="space-y-4 text-sm">
          <li><a href="#" class="hover:text-white transition">Hogar</a></li>
          <li><a href="#" class="hover:text-white transition">Auto</a></li>
          <li><a href="#" class="hover:text-white transition">Vida</a></li>
          <li><a href="#" class="hover:text-white transition">Comercial</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-bold mb-6">Contacto</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex gap-3">
            <span class="text-blue-500">📍</span>
            <span>Av. Apoquindo 4800, <br/> Las Condes, Santiago</span>
          </li>
          <li class="flex gap-3">
            <span class="text-blue-500">📞</span>
            <span>+56 9 1234 5678</span>
          </li>
          <li class="flex gap-3">
            <span class="text-blue-500">✉️</span>
            <span>contacto@macg.cl</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <p>© 2026 CORREDORA MACG. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition">Términos y Condiciones</a>
        <a href="#" class="hover:text-white transition">Privacidad</a>
        <a href="#" class="hover:text-white transition">Cookies</a>
      </div>
    </div>

  </div>
</footer>