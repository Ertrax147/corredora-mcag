---
// src/components/Hero.astro
---

<section class="relative bg-[#0f172a] pt-32 pb-20 overflow-hidden">
  <div
    class="absolute top-0 right-0 w-1/3 h-full bg-blue-600/10 blur-[120px] rounded-full"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="relative z-10">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-blue-400 text-xs font-semibold mb-6"
        >
          <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
          Líderes en el Mercado Inmobiliario
        </div>

        <h1
          class="text-5xl lg:text-7xl font-extrabold text-white leading-tight mb-6"
        >
          Tu Próximo <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400"
            >Hogar te Espera</span
          >
        </h1>

        <p class="text-gray-400 text-lg mb-8 max-w-lg">
          Descubre propiedades excepcionales que se adaptan a tu estilo de vida.
          Expertos en arriendos y ventas con más de 15 años de experiencia.
        </p>

        <div class="bg-white rounded-2xl p-2 shadow-2xl max-w-md">
          <div class="flex p-1 bg-slate-100 rounded-xl mb-2">
            <button
              class="flex-1 py-2 text-sm font-bold text-slate-400 rounded-lg hover:text-slate-600 transition"
              >Comprar</button
            >
            <button
              class="flex-1 py-2 text-sm font-bold bg-white text-slate-900 rounded-lg shadow-sm"
              >Arrendar</button
            >
          </div>
          <div
            class="flex items-center px-4 py-3 gap-3 border-t border-gray-100"
          >
            <svg
              class="w-5 h-5 text-gray-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
            >
            <input
              type="text"
              placeholder="¿Dónde quieres vivir?"
              class="w-full text-sm text-slate-800 outline-none placeholder:text-gray-400"
            />
            <button
              class="bg-blue-600 text-white p-2 rounded-lg hover:bg-blue-700 transition"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path></svg
              >
            </button>
          </div>
        </div>

        <div class="flex gap-10 mt-12">
          <div>
            <p class="text-3xl font-bold text-white">2.5k+</p><p
              class="text-gray-500 text-xs uppercase tracking-widest mt-1"
            >
              Propiedades
            </p>
          </div>
          <div>
            <p class="text-3xl font-bold text-white">98%</p><p
              class="text-gray-500 text-xs uppercase tracking-widest mt-1"
            >
              Satisfacción
            </p>
          </div>
          <div>
            <p class="text-3xl font-bold text-white">15+</p><p
              class="text-gray-500 text-xs uppercase tracking-widest mt-1"
            >
              Años
            </p>
          </div>
        </div>
      </div>

      <div class="relative group">
        <div
          class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-emerald-600 rounded-3xl blur opacity-25 group-hover:opacity-40 transition duration-1000"
        >
        </div>
        <div
          class="relative bg-slate-900 rounded-3xl overflow-hidden shadow-2xl"
        >
          <img
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=1000&auto=format&fit=crop"
            alt="Villa Moderna"
            class="w-full h-[500px] object-cover"
          />
          <div
            class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur-sm p-6 rounded-2xl"
          >
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-slate-900 font-bold text-xl">
                  Villa Moderna Premium
                </h3>
                <p class="text-slate-500 text-sm">Las Condes, Santiago</p>
              </div>
              <span
                class="bg-blue-100 text-blue-700 px-3 py-1 rounded-md text-[10px] font-black uppercase tracking-wider"
                >Destacado</span
              >
            </div>
            <div class="flex justify-between items-end mt-4">
              <p class="text-2xl font-black text-slate-900">$320.000.000</p>
              <div class="flex gap-3 text-slate-400 text-[11px] font-medium">
                <span>5 Hab.</span><span>4 Baños</span><span>450 m²</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
