---
// src/components/Navbar.astro
---

<nav
  class="fixed w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      <div class="flex flex-col leading-tight">
        <span class="text-xl font-bold text-slate-900 tracking-tight"
          >CORREDORA MACG</span
        >
        <span
          class="text-[10px] text-slate-500 font-medium tracking-[0.2em] uppercase"
          >Propiedades y Seguros</span
        >
      </div>

      <div class="hidden md:flex space-x-8 items-center">
        <a
          href="#propiedades"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
          >Propiedades</a
        >
        <a
          href="#seguros"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
          >Seguros</a
        >
        <a
          href="#nosotros"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
          >Nosotros</a
        >
        <a
          href="#contacto"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
          >Contacto</a
        >

        <button
          class="bg-[#1e293b] text-white px-6 py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-800 transition-all shadow-sm"
        >
          Agendar Cita
        </button>
      </div>
    </div>
  </div>
</nav>
