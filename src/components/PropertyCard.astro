---
// src/components/PropertyCard.astro
interface Props {
  title: string;
  location: string;
  price: string;
  image: string;
  type: "Venta" | "Arriendo";
  beds: number;
  baths: number;
  sqm: number;
  isTop?: boolean;
}

const { title, location, price, image, type, beds, baths, sqm, isTop } = Astro.props;
---

<div class="bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 group">
  <div class="relative overflow-hidden">
    <img src={image} alt={title} class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-500" />
    <div class="absolute top-4 left-4 flex gap-2">
      <span class={`px-3 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider text-white backdrop-blur-md ${type === "Venta" ? "bg-slate-900/80" : "bg-blue-600/80"}`}>
        {type}
      </span>
      {isTop && <span class="bg-yellow-400 text-slate-900 px-3 py-1 rounded-lg text-[10px] font-bold uppercase shadow-sm">⭐ Top</span>}
    </div>
  </div>
  <div class="p-6 text-slate-900">
    <p class="text-gray-400 text-xs mb-1 italic">{location}</p>
    <h3 class="text-lg font-bold mb-4 line-clamp-1">{title}</h3>
    <div class="flex justify-between border-t border-gray-100 pt-4 items-center">
      <div class="flex gap-3 text-slate-500 text-[11px]">
        <span><strong>{beds}</strong> Hab.</span>
        <span><strong>{sqm}</strong> m²</span>
      </div>
      <p class="text-emerald-600 font-black text-xl">{price}</p>
    </div>
  </div>
</div>