---
// src/layouts/Layout.astro
import "../styles/global.css"; // <--- ESTO ES VITAL
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-[#0f172a] text-white">
    <slot />
  </body>
</html>
