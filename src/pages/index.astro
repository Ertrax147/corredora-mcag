---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import FeaturedProperties from "../components/FeaturedProperties.astro";
import AboutUs from "../components/AboutUs.astro";
import InsuranceSection from "../components/InsuranceSection.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="CORREDORA MACG | Test de Estilos">
  <Navbar />
  <main>
    <Hero />

    <section class="py-20 bg-slate-950 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4">
        <h2
          class="text-white text-center text-4xl font-black mb-16 tracking-tighter"
        >
          DIAGNÓSTICO DE TAILWIND V4
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <div
            class="group relative p-1 rounded-3xl bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-600 hover:bg-gradient-to-l transition-all duration-700 shadow-[0_0_20px_rgba(6,182,212,0.3)] hover:shadow-[0_0_40px_rgba(6,182,212,0.6)]"
          >
            <div
              class="bg-slate-900 p-10 rounded-[22px] h-full flex flex-col justify-center"
            >
              <span
                class="text-cyan-400 font-mono text-xs mb-4 uppercase tracking-widest"
                >Test 01</span
              >
              <h3 class="text-3xl font-black text-white mb-2">NEÓN</h3>
              <p class="text-slate-400 text-sm">
                Si el borde brilla con colores y cambia al pasar el mouse, el
                motor de gradientes está activo.
              </p>
            </div>
          </div>

          <div
            class="relative p-10 rounded-3xl bg-white/5 border border-white/10 backdrop-blur-2xl shadow-2xl overflow-hidden group"
          >
            <div
              class="absolute -top-12 -right-12 w-32 h-32 bg-purple-600 rounded-full blur-[60px] group-hover:bg-pink-500 transition-colors"
            >
            </div>
            <div class="relative z-10">
              <span
                class="text-purple-400 font-mono text-xs mb-4 uppercase tracking-widest"
                >Test 02</span
              >
              <h3 class="text-3xl font-black text-white mb-2">CRISTAL</h3>
              <p class="text-slate-300 text-sm">
                Si ves el fondo desenfocado y manchas de color púrpura detrás
                del texto, el efecto de transparencia está OK.
              </p>
            </div>
          </div>

          <div
            class="p-10 rounded-3xl bg-white hover:-rotate-2 hover:-translate-y-6 hover:shadow-[20px_40px_80px_rgba(0,0,0,0.4)] transition-all duration-500 cursor-pointer group"
          >
            <span
              class="text-slate-400 font-mono text-xs mb-4 uppercase tracking-widest"
              >Test 03</span
            >
            <h3 class="text-3xl font-black text-slate-900 mb-2">3D FLOAT</h3>
            <p class="text-slate-600 text-sm font-medium">
              Si esta tarjeta blanca se inclina, sube y proyecta una sombra
              gigante al tocarla, las animaciones funcionan.
            </p>
          </div>
        </div>
      </div>
    </section>

    <FeaturedProperties />
    <AboutUs />
    <InsuranceSection />
  </main>
  <Footer />
</Layout>
